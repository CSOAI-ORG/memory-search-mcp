{
  "name": "memory-search-mcp",
  "description": "MCP server for memory search. Features record memory, search memory, add knowledge. From MEOK AI Labs.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "record_memory",
      "description": "Record a memory episode with care-weighting and emotional valence.",
      "parameters": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string"
          },
          "source_agent": {
            "type": "string"
          },
          "memory_type": {
            "type": "string"
          },
          "care_weight": {
            "type": "number"
          },
          "importance": {
            "type": "number"
          },
          "emotional_valence": {
            "type": "number"
          },
          "tags": {
            "type": "array"
          },
          "parent_id": {
            "type": "string"
          }
        },
        "required": [
          "content"
        ]
      }
    },
    {
      "name": "search_memory",
      "description": "Semantic search across all memories using full-text search with relevance ranking.",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          },
          "care_weight_min": {
            "type": "number"
          },
          "memory_type": {
            "type": "string"
          },
          "tags": {
            "type": "array"
          }
        },
        "required": [
          "query"
        ]
      }
    },
    {
      "name": "add_knowledge",
      "description": "Add a knowledge entry to the persistent knowledge base.",
      "parameters": {
        "type": "object",
        "properties": {
          "topic": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "confidence": {
            "type": "number"
          },
          "tags": {
            "type": "array"
          }
        },
        "required": [
          "topic",
          "content"
        ]
      }
    },
    {
      "name": "search_knowledge",
      "description": "Search the knowledge base by topic or content. Returns facts and reference",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          },
          "min_confidence": {
            "type": "number"
          }
        },
        "required": [
          "query"
        ]
      }
    },
    {
      "name": "list_memories",
      "description": "List recent memories, optionally filtered by type. Sort by created_at,",
      "parameters": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer"
          },
          "memory_type": {
            "type": "string"
          },
          "sort_by": {
            "type": "string"
          }
        },
        "required": []
      }
    },
    {
      "name": "get_memory_stats",
      "description": "Get statistics about the memory store: total count, type breakdown,",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "get_temporal_chain",
      "description": "Follow the temporal chain from a memory episode forward or backward in time.",
      "parameters": {
        "type": "object",
        "properties": {
          "episode_id": {
            "type": "string"
          },
          "direction": {
            "type": "string"
          },
          "max_steps": {
            "type": "integer"
          }
        },
        "required": [
          "episode_id"
        ]
      }
    },
    {
      "name": "consolidate_memories",
      "description": "Consolidate old, low-access memories by summarizing and archiving them.",
      "parameters": {
        "type": "object",
        "properties": {
          "older_than_days": {
            "type": "integer"
          },
          "min_access": {
            "type": "integer"
          }
        },
        "required": []
      }
    },
    {
      "name": "semantic_search",
      "description": "Semantic search using TF-IDF cosine similarity (no external deps).",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "top_k": {
            "type": "integer"
          }
        },
        "required": [
          "query"
        ]
      }
    }
  ]
}